{
  "name": "job-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run --prefix backend dev",
    "dev:python": "backend\\.venv\\Scripts\\uvicorn app.main:app --app-dir backend --reload --port 8000",
    "dev:db": "npm run --prefix backend prisma dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\" \"npm run dev:python\" \"npm run dev:db\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.454.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.17.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "eslint": "^9.15.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.1"
  }
}
