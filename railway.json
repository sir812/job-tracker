{
  "services": [
    {
      "name": "backend",
      "path": "backend",
      "build": "npm ci --production=false && npx prisma generate && npm run build",
      "start": "npx prisma migrate deploy && node dist/src/index.js",
      "env": ["DATABASE_URL", "JWT_SECRET", "AI_BACKEND_URL"]
    },
    {
      "name": "frontend",
      "path": ".",
      "build": "npm ci && npm run build",
      "start": "npm start",
      "env": ["NEXT_PUBLIC_API_URL", "VITE_API_BASE_URL", "VITE_AI_API_BASE_URL"]
    },
    {
      "name": "ai-backend",
      "path": "backend",
      "start": "uvicorn app.main:app --host 0.0.0.0 --port $PORT",
      "env": ["GROQ_API_KEY", "EXPRESS_API_BASE"]
    }
  ]
}
